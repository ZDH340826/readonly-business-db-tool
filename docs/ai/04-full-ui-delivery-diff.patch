+    private void appendMonitorLogRows() {
+        if (!Files.exists(logPath)) {
+            return;
+        }
+        try {
+            List<String> lines = Files.readAllLines(logPath, StandardCharsets.UTF_8);
+            int start = Math.max(0, lines.size() - 200);
+            for (int i = start; i < lines.size(); i++) {
+                addSystemLogRow("", "运行日志", "信息", "", sanitizeVisibleLog(lines.get(i)), "monitor.log");
+            }
+        } catch (Exception ex) {
+            addSystemLogRow(TIME_FORMAT.format(LocalDateTime.now()), "日志读取失败", "警告", "",
+                    sanitizedExceptionSummary(ex), "monitor.log");
+        }
+    }
