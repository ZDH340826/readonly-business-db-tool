+    private void appendSystemLogRows(Path path, String source) {
+        if (!Files.exists(path)) {
+            return;
+        }
+        try {
+            List<String> lines = Files.readAllLines(path, StandardCharsets.UTF_8);
+            for (int i = 1; i < lines.size(); i++) {
+                List<String> columns = parseCsvLine(lines.get(i));
+                if (columns.size() < 2) {
+                    continue;
+                }
+                String type = source.equals("事件日志") ? eventTypeText(columns.get(1)) : "检测完成";
+                String groupId = columns.size() > 2 ? columns.get(2) : "";
+                String description = columns.isEmpty() ? "" : columns.get(columns.size() - 1);
+                addSystemLogRow(columns.get(0), type, "信息", groupId, sanitizeVisibleLog(description), source);
+            }
+        } catch (Exception ex) {
+            addSystemLogRow(TIME_FORMAT.format(LocalDateTime.now()), "日志读取失败", "警告", "",
+                    sanitizedExceptionSummary(ex), source);
+        }
+    }
