+    private String eventTypeText(String eventType) {
+        if ("ALERT_OPEN".equals(eventType)) {
+            return "报警触发";
+        }
+        if ("ACKNOWLEDGED".equals(eventType)) {
+            return "已关注";
+        }
+        if ("RECOVERED".equals(eventType)) {
+            return "恢复";
+        }
+        if ("QUERY_FAILED".equals(eventType)) {
+            return "查询失败";
+        }
+        if ("QUERY_RECOVERED".equals(eventType)) {
+            return "查询恢复";
+        }
+        return eventType == null || eventType.isBlank() ? "检测完成" : eventType;
+    }
