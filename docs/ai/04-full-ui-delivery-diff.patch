+    private void addSystemLogRow(String time, String type, String level, String groupId, String description, String source) {
+        String selectedType = String.valueOf(systemLogTypeFilterBox.getSelectedItem());
+        String keyword = systemLogKeywordField.getText().trim();
+        String from = systemLogFromField.getText().trim();
+        String to = systemLogToField.getText().trim();
+        String groupFilter = systemLogGroupField.getText().trim();
+        if (!"全部".equals(selectedType) && !selectedType.equals(type)) {
+            return;
+        }
+        if (!groupFilter.isBlank() && !groupId.contains(groupFilter)) {
+            return;
+        }
+        if (!from.isBlank() && !time.isBlank() && time.compareTo(from) < 0) {
+            return;
+        }
+        if (!to.isBlank() && !time.isBlank() && time.compareTo(to) > 0) {
+            return;
+        }
+        String combined = time + " " + type + " " + groupId + " " + description + " " + source;
+        if (!keyword.isBlank() && !combined.contains(keyword)) {
+            return;
+        }
+        systemLogModel.addRow(new Object[] {time, type, level, groupId, description, source});
+    }
