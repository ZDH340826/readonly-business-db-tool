+            setField(appRef[0], "activeDialog", new JDialog(appRef[0], "active A"));
+            setField(appRef[0], "activeDialogGroupId", group.id());
+            @SuppressWarnings("unchecked")
+            Map<String, GroupAlertStatus> statuses =
